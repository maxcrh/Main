<apex:page standardController="Opportunity" recordsetvar="ops" sidebar="false">
    <apex:form >
    	<apex:pageBlock >
        	<apex:pageBlockButtons >
            	<apex:commandButton value="Salvar registros" action="{!save}"/>
            </apex:pageBlockButtons>
            <apex:pageBlockTable value="{!ops}" var="opp">
                <apex:column value="{!opp.name}"/>            	
                <apex:column headerValue="Stage">
                    <apex:inputField value="{!opp.StageName}"/>
                </apex:column>
                <apex:column headerValue="Data de encerramento da oportunidade">
                    <apex:inputField value="{!opp.CloseDate}"/>
                </apex:column>
            </apex:pageBlockTable>
        </apex:pageBlock>
    </apex:form>
</apex:page>