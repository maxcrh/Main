<aura:component >
    <aura:attribute name="expenses" type="ExpenseCar__c[]"/>
    
    <lightning:card title="Expenses">
        <p class="slds-p-horizontal_small">
            <aura:iteration items="{!v.expenses}" var="expense">
                <c:CarMaintenceItem expense="{!expense}"/>
            </aura:iteration>
        </p>
    </lightning:card>
</aura:component>