<aura:component controller="HeroesController">
    //Lista não usada nesse projeto.
    <aura:attribute name="heroes" type="Character__c[]"/>
    <aura:attribute name="newHero" type="Character__c"/>
    //vai ficar escutando o evento que vai ser chamado pelo chama o método
    <aura:handler name="createHero" event="c:heroEvent" action="{!c.handleCreateHero}"/>
	<!-- PAGE HEADER -->
    <lightning:layout class="slds-page-header slds-page-header_object-home">
        <lightning:layoutItem>
            <lightning:icon iconName="standard:scan_card" alternativeText="Heroes Register"/>
        </lightning:layoutItem>
        <lightning:layoutItem padding="horizontal-small">
            <div class="page-section page-header">
                <h1 class="slds-text-heading_label">Heroes</h1>
                <h2 class="slds-text-heading_medium">My Heores</h2>
            </div>
        </lightning:layoutItem>
    </lightning:layout>
    <!-- / PAGE HEADER -->
    <!-- NEW EXPENSE FORM -->
    <lightning:layout>
        <lightning:layoutItem padding="around-small" size="6">
            <c:heroesForm/>
        </lightning:layoutItem>
    </lightning:layout>
    <!-- / NEW EXPENSE FORM -->	
</aura:component>